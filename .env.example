# ---------------------------------------------------------------------------
# Copy to .env and fill in values. Do not commit .env.
# After Terraform apply, get DATABASE_URL:  export DATABASE_URL=$(./scripts/get_db_url_from_terraform.sh)
# ---------------------------------------------------------------------------

# Google (optional; for search_agent, research_agent)
GOOGLE_API_KEY="your-google-api-key"

# AWS – required for jobs agent (Bedrock) and for Terraform
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"

# Web search – jobs agent (Tavily first, Brave fallback)
TAVILY_API_KEY="tvly-..."
BRAVE_SEARCH_API_KEY="..."

# Google Jobs – jobs agent (same as google.com/search?q=...&udm=8; parsed descriptions + apply links)
# Get key: https://serpapi.com/manage-api-key
SERPAPI_API_KEY="..."
# Optional: SERPAPI_GL=us, SERPAPI_HL=en, SERPAPI_LOCATION="Austin, Texas, United States"

# Database – from Terraform RDS after: terraform apply
# Get URL:  export DATABASE_URL=$(./scripts/get_db_url_from_terraform.sh)
# Or:      echo "DATABASE_URL=$(./scripts/get_db_url_from_terraform.sh)" >> .env
DATABASE_URL="postgresql://user:password@localhost:5432/agentics"

# Chroma – optional; from Terraform after apply: terraform output chroma_host
# CHROMA_HOST="1.2.3.4"
# CHROMA_PORT="8000"

# Optional: Chroma data path when running Chroma locally (default: data/chroma_db)
# CHROMA_DATA_PATH="data/chroma_db"

# Optional: Bedrock embedding model
# BEDROCK_EMBED_MODEL="amazon.titan-embed-text-v2:0"

# JWT auth – set a stable secret for production (auto-generated if unset)
# JWT_SECRET="change-me-to-a-long-random-string"
# JWT_ALGORITHM="HS256"
# JWT_EXPIRATION_HOURS=72

# Optional: Job crawl default query (Option C batch)
# JOB_CRAWL_QUERY="software engineer jobs"
